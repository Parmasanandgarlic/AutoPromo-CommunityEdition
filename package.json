{
  "name": "react-example",
  "private": true,
  "version": "1.0.0",
  "description": "AutoPROMO Agent - Advanced Automation Suite",
  "author": "AutoPROMO Team",
  "type": "module",
  "main": "electron-main.js",
  "scripts": {
    "dev": "tsx server.ts",
    "build": "vite build",
    "build:server": "esbuild server.ts --bundle --platform=node --format=esm --outfile=server.js --external:sqlite3 --external:telegram --external:express --external:cors --external:vite",
    "build:electron": "esbuild electron-main.ts --bundle --platform=node --format=esm --outfile=electron-main.js --external:electron --external:electron-is-dev",
    "preview": "vite preview",
    "clean": "rm -rf dist release server.js electron-main.js",
    "lint": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "start": "tsx server.ts",
    "build:all": "npm install && npm run electron:build",
    "electron:dev": "concurrently \"npm run dev\" \"wait-on http://localhost:3000 && electron .\"",
    "electron:build": "npm run build && npm run build:server && npm run build:electron && electron-builder",
    "electron:build:win": "npm run build && npm run build:server && npm run build:electron && electron-builder --win"
  },
  "build": {
    "appId": "com.autopromo.agent",
    "productName": "AutoPROMO agent",
    "npmRebuild": false,
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron-main.js",
      "server.js",
      "agent_db.json",
      "package.json"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.90.0",
    "@google/genai": "^1.29.0",
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "clsx": "^2.1.1",
    "cors": "^2.8.6",
    "dotenv": "^17.4.0",
    "express": "^4.22.1",
    "express-rate-limit": "^8.3.2",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "openai": "^6.34.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "sqlite": "^5.1.1",
    "sqlite3": "^5.1.7",
    "tailwind-merge": "^3.5.0",
    "telegram": "^2.26.22",
    "vite": "^6.2.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.25",
    "@types/node": "^22.14.0",
    "@types/sqlite3": "^3.1.11",
    "@types/supertest": "^7.2.0",
    "autoprefixer": "^10.4.21",
    "concurrently": "^9.2.1",
    "electron": "^34.0.0",
    "electron-builder": "^26.8.1",
    "electron-is-dev": "^3.0.1",
    "esbuild": "^0.27.5",
    "jsdom": "^29.0.2",
    "supertest": "^7.2.2",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.0",
    "vitest": "^4.1.4",
    "wait-on": "^9.0.4"
  }
}
