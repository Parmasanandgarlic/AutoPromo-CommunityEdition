{
  "manifest_version": 3,
  "name": "AutoPROMO agent",
  "version": "1.0.0",
  "description": "Headless automation suite. Features: Auto-DM, Auto-React, Auto-Join, Scraper, and Keyword Listener.",
  "action": {
    "default_popup": "index.html",
    "default_title": "Open AutoPROMO"
  },
  "icons": {
    "128": "icon.png"
  },
  "permissions": [
    "storage",
    "activeTab",
    "scripting"
  ],
  "host_permissions": [
    "http://localhost:3000/*",
    "https://*.telegram.org/*"
  ]
}
